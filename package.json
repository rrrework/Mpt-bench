{
  "name": "mpt-bench",
  "version": "1.0.0",
  "description": "MPT - Multi-channel LLM stress testing tool (RPM/TTFT/TPS/P95). Supports OpenAI-compatible APIs, SSE streaming, adaptive scheduling, and multi-model benchmarking.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mpt": "./bin/mpt.js"
  },
  "scripts": {
    "start": "node bin/mpt.js",
    "dev": "node --watch bin/mpt.js",
    "run": "node bin/mpt.js run",
    "test": "echo \"Tests pending\" && exit 0"
  },
  "keywords": [
    "llm",
    "stress-test",
    "benchmark",
    "performance",
    "model-test",
    "openai",
    "channel"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
